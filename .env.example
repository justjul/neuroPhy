# neuroPhy Environment Configuration
# Copy this file to .env and adjust values as needed

# ============================================================================
# Server Configuration
# ============================================================================

# Frontend (Dash GUI) - Port 8051 (avoids conflicts with your docker-compose ports)
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8051
FRONTEND_DEBUG=true

# Backend API - Port 8001 (avoids conflicts with your docker-compose ports)
API_HOST=0.0.0.0
API_PORT=8001
API_DEBUG=true
API_RELOAD=true

# API URL (used by frontend to connect to backend)
API_URL=http://localhost:8001

# ============================================================================
# Data Paths
# ============================================================================

# Root directory for all data
DATA_ROOT=/path/to/your/data

# Note: The following are auto-generated under DATA_ROOT:
# - processed/  (processed data)
# - raw/        (raw data)
# - results/    (analysis results)

# ============================================================================
# Session Configuration
# ============================================================================

# Session timeout in seconds (default: 1 hour)
SESSION_TIMEOUT=3600

# Maximum concurrent sessions
MAX_SESSIONS=10

# ============================================================================
# Performance Settings
# ============================================================================

# Number of worker processes for computations
N_WORKERS=4

# Enable caching
ENABLE_CACHE=true

# ============================================================================
# Logging
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# Development Settings
# ============================================================================

# Enable development mode
DEV_MODE=true

# Enable CORS (useful for development)
ENABLE_CORS=true

# ============================================================================
# Docker Configuration (when running in containers)
# ============================================================================

# These ports are exposed when running via docker-compose
DOCKER_FRONTEND_PORT=8051
DOCKER_API_PORT=8001